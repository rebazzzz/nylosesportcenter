PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3001
PUBLIC_APP_URL=http://localhost:3001
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
ENCRYPTION_KEY=replace-with-64-random-hex-characters
DB_PATH=./database/nylose.db

# Optional bootstrap admin for first run
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=replace-with-a-strong-admin-password

# Brevo transactional email
BREVO_API_KEY=your-brevo-api-key
BREVO_API_URL=https://api.brevo.com/v3/smtp/email
EMAIL_FROM=noreply@example.com
EMAIL_FROM_NAME=Nylöse SportCenter
EMAIL_REPLY_TO=nylosesportcenter@gmail.com
EMAIL_INVOICE_INTERVAL_MINUTES=60

# Payment details shown in the invoice email after the 2 week trial
PAYMENT_SWISH=
PAYMENT_BANKGIRO=
PAYMENT_PLUSGIRO=
PAYMENT_ACCOUNT_NAME=Nylöse SportCenter
